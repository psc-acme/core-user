{
    "name": "psc-acme/core-user",
    "description": "Package core-user for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\CoreUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "predis/predis": "^2.0",
        "symfony/yaml": "^7.0",
        "brick/date-time": "^0.7.1",
        "doctrine/collections": "^2.0",
        "symfony/symfony": "^6.3",
        "guzzlehttp/psr7": "^2.0",
        "psc-acme/toolkit-auth": "^1.0"
    },
    "require-dev": {
        "infection/infection": "^0.27",
        "phpunit/phpunit": "^11.0",
        "symfony/phpunit-bridge": "^7.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}